---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
---

<Layout title="Services">
	<section class="bg-[#15303e] text-white pt-20 md:pt-32 pb-24 md:pb-32 flex items-center justify-center relative overflow-hidden">
		<!-- Large faded background logo -->
		<div class="absolute top-12 -right-24 w-80 md:w-[600px] opacity-[0.05] pointer-events-none select-none reveal-fade-up !opacity-[0.05]" style="transition-duration: 2s;">
			<Image src={logo} alt="" class="w-full h-auto brightness-0 invert" />
		</div>

		<div class="container mx-auto px-6 z-10">
			<div class="max-w-5xl">
				<div class="flex items-center gap-4 md:gap-6 mb-8 md:mb-12">
					<div class="w-12 h-12 md:w-20 md:h-20 shrink-0 relative reveal-fade-up">
						<div class="absolute inset-0 bg-[#a0ceca]/10 blur-2xl scale-110"></div>
						<Image src={logo} alt="Hidden Hills Bookkeeping Logo" class="w-full h-auto relative z-10 brightness-0 invert" />
					</div>
					<div class="h-[1px] flex-grow bg-white/10 hidden md:block reveal-line"></div>
					<span class="text-[10px] md:text-xs uppercase tracking-[0.4em] font-bold text-white/40 whitespace-nowrap reveal-fade-up">Capabilities</span>
				</div>

				<h1 class="text-5xl md:text-8xl lg:text-9xl font-bold mb-8 md:mb-10 tracking-tighter font-['EB_Garamond'] leading-[0.85] md:leading-[0.8] text-balance reveal-hero">
					Services <br class="hidden md:block" /><span class="italic font-normal opacity-80">Offered.</span>
				</h1>
				
				<div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-8 md:gap-12 mt-12 md:mt-16 reveal-fade-up">
					<p class="text-lg md:text-2xl text-white/70 leading-relaxed font-light max-w-xl">
						Comprehensive administrative and financial solutions tailored to help your organization scale with precision.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 md:gap-6 shrink-0 w-full md:w-auto">
						<a href="/contact" class="group relative inline-flex items-center justify-center px-8 md:px-10 py-4 bg-[#a0ceca] text-[#15303e] font-bold text-xs uppercase tracking-widest overflow-hidden transition-all hover:scale-105 active:scale-95">
							<span class="relative z-10">Request a Quote</span>
							<div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 md:py-24 bg-[#FCFAFA]">
		<div class="container mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-px bg-[#15303e]/5 overflow-hidden border border-[#15303e]/5">
				<!-- Bookkeeping -->
				<div class="p-10 md:p-16 bg-white hover:bg-[#FCFAFA] transition-all group relative reveal-fade-up">
					<span class="text-4xl md:text-5xl font-['EB_Garamond'] text-[#a0ceca]/20 absolute top-6 md:top-8 right-6 md:right-8 select-none group-hover:text-[#a0ceca] transition-colors">01</span>
					<div class="w-12 h-[1px] bg-[#a0ceca] mb-8"></div>
					<h2 class="text-2xl md:text-3xl font-bold mb-6 text-[#15303e] font-['EB_Garamond'] leading-tight">Bookkeeping</h2>
					<p class="text-[#15303e]/60 leading-relaxed text-base md:text-lg font-light mb-8">
						Comprehensive monthly management of your business finances to keep your records accurate and your growth on track.
					</p>
					<ul class="space-y-3 text-[10px] md:text-xs uppercase tracking-widest font-bold text-[#15303e]">
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Monthly Income & Expense Categorization</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Monthly Bank Reconciliations</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Monthly P&L and Balance Sheet</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Invoicing (A/R) and Bill Pay (A/P)</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Unlimited Support via Email</li>
					</ul>
				</div>

				<!-- Fractional CFO -->
				<div class="p-10 md:p-16 bg-white hover:bg-[#FCFAFA] transition-all group relative reveal-fade-up" style="transition-delay: 100ms;">
					<span class="text-4xl md:text-5xl font-['EB_Garamond'] text-[#a0ceca]/20 absolute top-6 md:top-8 right-6 md:right-8 select-none group-hover:text-[#a0ceca] transition-colors">02</span>
					<div class="w-12 h-[1px] bg-[#a0ceca] mb-8"></div>
					<h2 class="text-2xl md:text-3xl font-bold mb-6 text-[#15303e] font-['EB_Garamond'] leading-tight">Fractional CFO</h2>
					<p class="text-[#15303e]/60 leading-relaxed text-base md:text-lg font-light mb-8">
						Strategic financial leadership providing the insights and analysis needed to drive profitability and scale your organization.
					</p>
					<ul class="space-y-3 text-[10px] md:text-xs uppercase tracking-widest font-bold text-[#15303e]">
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Strategic Planning</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Budgeting & Forecasting</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Job Costing</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Profitability Analysis</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Additional Custom Analyses</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Plus Bookkeeping</li>
					</ul>
				</div>

				<!-- Consulting -->
				<div class="p-10 md:p-16 bg-white hover:bg-[#FCFAFA] transition-all group relative reveal-fade-up" style="transition-delay: 200ms;">
					<span class="text-4xl md:text-5xl font-['EB_Garamond'] text-[#a0ceca]/20 absolute top-6 md:top-8 right-6 md:right-8 select-none group-hover:text-[#a0ceca] transition-colors">03</span>
					<div class="w-12 h-[1px] bg-[#a0ceca] mb-8"></div>
					<h2 class="text-2xl md:text-3xl font-bold mb-6 text-[#15303e] font-['EB_Garamond'] leading-tight">Consulting</h2>
					<p class="text-[#15303e]/60 leading-relaxed text-base md:text-lg font-light mb-8">
						Specialized assistance for setup, cleanup, or technical transitions, ensuring your systems are efficient and reliable.
					</p>
					<ul class="space-y-3 text-[10px] md:text-xs uppercase tracking-widest font-bold text-[#15303e]">
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Bookkeeping Setup or Catchup</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> QuickBooks Desktop to Online</li>
						<li class="flex items-center gap-4"><div class="w-1 h-1 bg-[#a0ceca]"></div> Custom Spreadsheet Automation</li>
					</ul>
				</div>
			</div>
			
			<div class="mt-16 md:mt-24 bg-[#15303e] p-10 md:p-24 text-center text-white relative overflow-hidden group reveal-fade-up">
				<div class="relative z-10">
					<h2 class="text-4xl md:text-7xl font-bold mb-6 md:mb-8 font-['EB_Garamond'] leading-none">Let's build something <br /><span class="italic font-normal opacity-40">efficient.</span></h2>
					<p class="text-[#a0ceca] text-lg md:text-2xl mb-8 md:mb-12 max-w-xl mx-auto font-light">I'd love to learn about your business and see how I can help you save time.</p>
					<a href="/contact" class="inline-flex items-center justify-center px-10 md:px-12 py-4 md:py-5 bg-[#a0ceca] text-[#15303e] font-bold text-xs uppercase tracking-[0.2em] transition-all hover:scale-105 active:scale-95 w-full md:w-auto">
						Request a Quote
					</a>
				</div>
				<div class="absolute inset-0 pointer-events-none overflow-hidden">
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 md:w-[600px] h-80 md:h-[600px] bg-[#a0ceca]/5 scale-150 group-hover:scale-110 transition-transform duration-1000"></div>
				</div>
			</div>
		</div>
	</section>
</Layout>
</Layout>
</Layout>