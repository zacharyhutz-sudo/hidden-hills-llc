---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
---

<Layout title="Services">
	<section class="bg-[#ACC7C7] text-[#2C3E50] pt-40 pb-32 flex items-center justify-center relative overflow-hidden">
		<div class="container mx-auto px-6 z-10">
			<div class="flex flex-col md:flex-row items-end justify-between gap-12">
				<div class="max-w-3xl">
					<span class="text-xs uppercase tracking-[0.3em] font-bold text-[#2C3E50]/40 mb-6 block">Capabilities</span>
					<h1 class="text-7xl md:text-9xl font-medium mb-10 tracking-tighter font-['Instrument_Serif'] leading-none">Services <br /><span class="italic font-normal">Offered.</span></h1>
				</div>
				<div class="w-32 md:w-48 shrink-0 pb-4">
					<Image src={logo} alt="Hidden Hills LLC Logo" class="w-full h-auto drop-shadow-xl opacity-20" style="filter: brightness(0) saturate(100%) invert(18%) sepia(26%) saturate(1088%) hue-rotate(169deg) brightness(93%) contrast(89%);" />
				</div>
			</div>
		</div>
	</section>

	<section class="py-40 bg-[#FCFAFA]">
		<div class="container mx-auto px-6">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-px bg-[#2C3E50]/5 rounded-[3rem] overflow-hidden border border-[#2C3E50]/5">
				<!-- Bookkeeping & Accounting -->
				<div class="p-16 md:p-24 bg-white hover:bg-[#FCFAFA] transition-all group relative">
					<span class="text-6xl font-['Instrument_Serif'] text-[#ACC7C7]/20 absolute top-12 right-12 select-none group-hover:text-[#ACC7C7] transition-colors">01</span>
					<div class="w-16 h-[1px] bg-[#ACC7C7] mb-12"></div>
					<h2 class="text-4xl font-medium mb-8 text-[#2C3E50] font-['Instrument_Serif'] leading-tight">Bookkeeping <br />& Accounting</h2>
					<p class="text-[#2C3E50]/60 leading-relaxed text-lg font-light mb-10 max-w-sm">
						Accurate records, expense categorization, invoicing, and bank reconciliations to keep your finances tidy and ready for growth.
					</p>
					<ul class="space-y-4 text-xs uppercase tracking-widest font-bold text-[#2C3E50]">
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Invoicing & AR</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Expense Categorization</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Bank Reconciliations</li>
					</ul>
				</div>

				<!-- Process Improvement -->
				<div class="p-16 md:p-24 bg-white hover:bg-[#FCFAFA] transition-all group relative">
					<span class="text-6xl font-['Instrument_Serif'] text-[#ACC7C7]/20 absolute top-12 right-12 select-none group-hover:text-[#ACC7C7] transition-colors">02</span>
					<div class="w-16 h-[1px] bg-[#ACC7C7] mb-12"></div>
					<h2 class="text-4xl font-medium mb-8 text-[#2C3E50] font-['Instrument_Serif'] leading-tight">Process <br />Improvement</h2>
					<p class="text-[#2C3E50]/60 leading-relaxed text-lg font-light mb-10 max-w-sm">
						Assessing financial protocols and recommending enhancements to boost efficiency, productivity, and cost-effectiveness.
					</p>
					<ul class="space-y-4 text-xs uppercase tracking-widest font-bold text-[#2C3E50]">
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Workflow Audits</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Productivity Consulting</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Operation Support</li>
					</ul>
				</div>

				<!-- Spreadsheet Creation/Automation -->
				<div class="p-16 md:p-24 bg-white hover:bg-[#FCFAFA] transition-all group relative border-t border-[#2C3E50]/5 lg:border-t-0">
					<span class="text-6xl font-['Instrument_Serif'] text-[#ACC7C7]/20 absolute top-12 right-12 select-none group-hover:text-[#ACC7C7] transition-colors">03</span>
					<div class="w-16 h-[1px] bg-[#ACC7C7] mb-12"></div>
					<h2 class="text-4xl font-medium mb-8 text-[#2C3E50] font-['Instrument_Serif'] leading-tight">Spreadsheet <br />Automation</h2>
					<p class="text-[#2C3E50]/60 leading-relaxed text-lg font-light mb-10 max-w-sm">
						Cleaning up and utilizing large data sets to automate processes and workflows, saving you hours of manual labor.
					</p>
					<ul class="space-y-4 text-xs uppercase tracking-widest font-bold text-[#2C3E50]">
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Workflow Automation</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Data Organization</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Custom Dashboards</li>
					</ul>
				</div>

				<!-- Other Special Projects -->
				<div class="p-16 md:p-24 bg-white hover:bg-[#FCFAFA] transition-all group relative">
					<span class="text-6xl font-['Instrument_Serif'] text-[#ACC7C7]/20 absolute top-12 right-12 select-none group-hover:text-[#ACC7C7] transition-colors">04</span>
					<div class="w-16 h-[1px] bg-[#ACC7C7] mb-12"></div>
					<h2 class="text-4xl font-medium mb-8 text-[#2C3E50] font-['Instrument_Serif'] leading-tight">Special <br />Projects</h2>
					<p class="text-[#2C3E50]/60 leading-relaxed text-lg font-light mb-10 max-w-sm">
						Assistance with miscellaneous high-impact projects like data entry, software transitions, and organizational overhauls.
					</p>
					<ul class="space-y-4 text-xs uppercase tracking-widest font-bold text-[#2C3E50]">
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Software Transitions</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Data Entry</li>
						<li class="flex items-center gap-4"><div class="w-1.5 h-1.5 rounded-full bg-[#ACC7C7]"></div> Historical Cleanup</li>
					</ul>
				</div>
			</div>
			
			<div class="mt-40 bg-[#2C3E50] rounded-[4rem] p-16 md:p-32 text-center text-white relative overflow-hidden group">
				<div class="relative z-10">
					<h2 class="text-5xl md:text-8xl font-medium mb-10 font-['Instrument_Serif'] leading-none">Let's build something <br /><span class="italic font-normal opacity-40">efficient.</span></h2>
					<p class="text-[#ACC7C7] text-xl md:text-2xl mb-16 max-w-xl mx-auto font-light">I'd love to learn about your business and see how I can help you save time.</p>
					<a href="/hidden-hills-llc/contact" class="inline-flex items-center justify-center px-16 py-6 bg-[#ACC7C7] text-[#2C3E50] rounded-full font-bold text-sm uppercase tracking-[0.2em] transition-all hover:scale-105 active:scale-95">
						Request a Quote
					</a>
				</div>
				<div class="absolute inset-0 pointer-events-none overflow-hidden">
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#ACC7C7]/5 rounded-full blur-3xl scale-150 group-hover:scale-110 transition-transform duration-1000"></div>
				</div>
			</div>
		</div>
	</section>
</Layout>