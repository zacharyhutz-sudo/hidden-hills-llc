---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You">
	<section class="bg-[#ACC7C7] text-[#2C3E50] py-32 flex items-center justify-center relative overflow-hidden flex-grow">
		<div class="container mx-auto px-6 z-10 text-center">
			<div class="max-w-2xl mx-auto">
				<span class="text-xs uppercase tracking-[0.3em] font-bold text-[#2C3E50]/40 mb-8 block">Success</span>
				<h1 class="text-7xl md:text-9xl font-bold mb-10 tracking-tighter font-['EB_Garamond'] leading-none">Thank <br /><span class="italic font-normal">You.</span></h1>
				<p class="text-xl md:text-2xl text-[#2C3E50]/70 mb-16 leading-relaxed font-light">
					Your message has been received. I'll review your details and get back to you shortly.
				</p>
				<a href="/hidden-hills-llc/" class="group inline-flex items-center justify-center px-12 py-5 bg-[#2C3E50] text-white font-bold text-xs uppercase tracking-[0.2em] transition-all hover:scale-105 active:scale-95 shadow-xl">
					Return Home
				</a>
			</div>
		</div>
		<div class="absolute inset-0 bg-gradient-to-b from-white/10 to-transparent pointer-events-none"></div>
	</section>
</Layout>