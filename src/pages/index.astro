---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
import curtis from '../assets/curtis-folsom.png';
---

<Layout title="Home">
	<section class="bg-[#ACC7C7] text-[#2C3E50] py-32 flex items-center justify-center relative overflow-hidden">
		<div class="container mx-auto px-6 z-10">
			<div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
				<div class="w-48 md:w-64 lg:w-72 shrink-0 relative">
					<div class="absolute inset-0 bg-[#2C3E50]/5 blur-3xl rounded-full scale-110"></div>
					<Image src={logo} alt="Hidden Hills LLC Logo" class="w-full h-auto relative z-10 drop-shadow-2xl" style="filter: brightness(0) saturate(100%) invert(18%) sepia(26%) saturate(1088%) hue-rotate(169deg) brightness(93%) contrast(89%);" />
				</div>
				<div class="text-left max-w-2xl">
					<h1 class="text-6xl md:text-8xl lg:text-9xl font-bold mb-8 tracking-tighter font-['EB_Garamond'] leading-[0.85] text-balance">
						Focus on what <br />you <span class="italic font-normal opacity-80">really love.</span>
					</h1>
					<p class="text-xl md:text-2xl text-[#2C3E50]/70 mb-10 leading-relaxed font-normal max-w-xl">
						I'm Curtis Folsom. I streamline the administrative load so you can focus on growth.
					</p>
					<div class="flex flex-col sm:flex-row gap-6">
						<a href="/hidden-hills-llc/services" class="group relative inline-flex items-center justify-center px-10 py-4 bg-[#2C3E50] text-white rounded-full font-bold text-xs uppercase tracking-widest overflow-hidden transition-all hover:scale-105 active:scale-95">
							<span class="relative z-10">View Services</span>
							<div class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
						</a>
						<a href="/hidden-hills-llc/contact" class="group inline-flex items-center justify-center px-10 py-4 border-2 border-[#2C3E50] text-[#2C3E50] rounded-full font-bold text-xs uppercase tracking-widest transition-all hover:bg-[#2C3E50] hover:text-white">
							Get in Touch
						</a>
					</div>
				</div>
			</div>
		</div>
		<div class="absolute inset-0 bg-gradient-to-r from-white/10 to-transparent pointer-events-none"></div>
	</section>

	<section class="py-24 md:py-32 bg-[#FCFAFA]">
		<div class="container mx-auto px-6">
			<div class="flex flex-col md:flex-row gap-16 md:gap-24 items-center">
				<div class="md:w-5/12 relative">
					<div class="relative z-10 group">
						<Image src={curtis} alt="Curtis Folsom" class="rounded-[2rem] shadow-[0_40px_80px_-15px_rgba(0,0,0,0.15)] w-full h-auto grayscale hover:grayscale-0 transition-all duration-700" />
					</div>
					<div class="absolute -top-10 -left-10 w-40 h-40 bg-[#ACC7C7] rounded-full -z-10 opacity-30 blur-2xl"></div>
				</div>
				<div class="md:w-7/12">
					<span class="text-xs uppercase tracking-[0.3em] font-bold text-[#ACC7C7] mb-6 block">The Person</span>
					<h2 class="text-5xl md:text-7xl font-bold text-[#2C3E50] mb-10 font-['EB_Garamond'] leading-tight">About Curtis</h2>
					<div class="space-y-6 text-lg md:text-xl text-[#2C3E50]/70 leading-relaxed font-light">
						<p>
							I have an accounting degree from the University of Georgia and have financial experience in multiple industries. 
							What fuels me is solving problems and creating efficient systems to save time and energy.
						</p>
						<p class="text-xl md:text-2xl font-normal text-[#2C3E50]">
							"From multi-billion-dollar corporations to local businesses, I bring elite-level knowledge to organizations of all sizes."
						</p>
					</div>
					<div class="mt-12">
						<a href="/hidden-hills-llc/contact" class="group inline-flex items-center gap-4 text-[#2C3E50] font-bold text-xs uppercase tracking-widest">
							<span>Start a Conversation</span>
							<div class="w-12 h-[1px] bg-[#ACC7C7] group-hover:w-20 transition-all duration-500"></div>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-24 bg-white border-y border-[#2C3E50]/5">
		<div class="container mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[#2C3E50]/5 rounded-[2.5rem] overflow-hidden border border-[#2C3E50]/5">
				<div class="p-12 md:p-16 lg:p-20 bg-white hover:bg-[#FCFAFA] transition-colors group">
					<span class="text-3xl font-['EB_Garamond'] text-[#ACC7C7] mb-6 block font-bold">01</span>
					<h3 class="text-3xl font-bold mb-4 text-[#2C3E50] font-['EB_Garamond'] group-hover:translate-x-2 transition-transform">Expert Systems</h3>
					<p class="text-[#2C3E50]/60 leading-relaxed text-lg font-light italic">Leading software transitions, historical data cleanup, and bookkeeping excellence.</p>
				</div>
				<div class="p-12 md:p-16 lg:p-20 bg-white hover:bg-[#FCFAFA] transition-colors group">
					<span class="text-3xl font-['EB_Garamond'] text-[#ACC7C7] mb-6 block font-bold">02</span>
					<h3 class="text-3xl font-bold mb-4 text-[#2C3E50] font-['EB_Garamond'] group-hover:translate-x-2 transition-transform">Local Expertise</h3>
					<p class="text-[#2C3E50]/60 leading-relaxed text-lg font-light italic">A business solutions company based in Athens, GA, helping local business owners succeed.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
</Layout>
