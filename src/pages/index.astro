---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
import curtis from '../assets/curtis-folsom.png';
---

<Layout title="Home">
	<section class="bg-[#15303e] text-white pt-20 md:pt-32 pb-24 md:pb-32 flex items-center justify-center relative overflow-hidden">
		<!-- Large faded background logo -->
		<div class="absolute top-12 -right-24 w-80 md:w-[600px] opacity-[0.05] pointer-events-none select-none reveal-fade-up !opacity-[0.05]" style="transition-duration: 2s;">
			<Image src={logo} alt="" class="w-full h-auto brightness-0 invert" />
		</div>

		<div class="container mx-auto px-6 z-10">
			<div class="max-w-5xl">
				<div class="flex items-center gap-4 md:gap-6 mb-8 md:mb-12">
					<div class="w-12 h-12 md:w-20 md:h-20 shrink-0 relative reveal-fade-up">
						<div class="absolute inset-0 bg-[#a0ceca]/10 blur-2xl scale-110"></div>
						<Image src={logo} alt="Hidden Hills Bookkeeping Logo" class="w-full h-auto relative z-10 brightness-0 invert" />
					</div>
					<div class="h-[1px] flex-grow bg-white/10 hidden md:block reveal-line"></div>
					<span class="text-[10px] md:text-xs uppercase tracking-[0.4em] font-bold text-white/40 whitespace-nowrap reveal-fade-up">Business Solutions</span>
				</div>

				<h1 class="text-5xl md:text-8xl lg:text-9xl font-bold mb-8 md:mb-10 tracking-tighter font-['EB_Garamond'] leading-[0.85] md:leading-[0.8] text-balance reveal-hero">
					Focus on what <br class="hidden md:block" />you <span class="italic font-normal opacity-80">really love.</span>
				</h1>
				
				<div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-8 md:gap-12 mt-12 md:mt-16 reveal-fade-up">
					<p class="text-lg md:text-2xl text-white/70 leading-relaxed font-light max-w-xl">
						I'm Curtis Folsom. I streamline the administrative load so you can focus on growth.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 md:gap-6 shrink-0 w-full md:w-auto">
						<a href="/hidden-hills-llc/services" class="group relative inline-flex items-center justify-center px-8 md:px-10 py-4 bg-[#a0ceca] text-[#15303e] font-bold text-xs uppercase tracking-widest overflow-hidden transition-all hover:scale-105 active:scale-95">
							<span class="relative z-10">View Services</span>
							<div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
						</a>
						<a href="/hidden-hills-llc/contact" class="group inline-flex items-center justify-center px-8 md:px-10 py-4 border-2 border-[#a0ceca] text-[#a0ceca] font-bold text-xs uppercase tracking-widest transition-all hover:bg-[#a0ceca] hover:text-[#15303e]">
							Get in Touch
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 md:py-32 bg-[#FCFAFA]">
		<div class="container mx-auto px-6">
			<div class="flex flex-col md:flex-row gap-12 md:gap-24 items-center">
				<div class="md:w-5/12 relative reveal-fade-up">
					<div class="relative z-10 group">
						<Image src={curtis} alt="Curtis Folsom" class="shadow-[0_40px_80px_-15px_rgba(0,0,0,0.15)] w-full h-auto transition-all duration-700" />
					</div>
					<div class="absolute -top-10 -left-10 w-40 h-40 bg-[#a0ceca] -z-10 opacity-30 blur-2xl"></div>
				</div>
				<div class="md:w-7/12 reveal-fade-up">
					<h2 class="text-4xl md:text-7xl font-bold text-[#15303e] mb-6 md:mb-10 font-['EB_Garamond'] leading-tight">About Curtis</h2>
					<div class="space-y-6 text-base md:text-xl text-[#15303e]/70 leading-relaxed font-light">
						<p>
							I have an accounting degree from the University of Georgia and have financial experience in multiple industries. 
							What fuels me is solving problems and creating efficient systems to save time and energy.
						</p>
						<p class="text-lg md:text-2xl font-normal text-[#15303e]">
							"From multi-billion-dollar corporations to local businesses, I bring elite-level knowledge to organizations of all sizes."
						</p>
					</div>
					<div class="mt-8 md:mt-12">
						<a href="/hidden-hills-llc/contact" class="group inline-flex items-center gap-4 text-[#15303e] font-bold text-xs uppercase tracking-widest">
							<span>Start a Conversation</span>
							<div class="w-12 h-[1px] bg-[#a0ceca] group-hover:w-20 transition-all duration-500"></div>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 bg-white border-y border-[#15303e]/5">
		<div class="container mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[#15303e]/5 overflow-hidden border border-[#15303e]/5">
				<div class="p-10 md:p-20 bg-white hover:bg-[#FCFAFA] transition-colors group reveal-fade-up">
					<span class="text-2xl md:text-3xl font-['EB_Garamond'] text-[#a0ceca] mb-4 md:mb-6 block font-bold">01</span>
					<h3 class="text-2xl md:text-3xl font-bold mb-4 text-[#15303e] font-['EB_Garamond'] group-hover:translate-x-2 transition-transform">Expert Systems</h3>
					<p class="text-[#15303e]/60 leading-relaxed text-base md:text-lg font-light italic">Leading software transitions, historical data cleanup, and bookkeeping excellence.</p>
				</div>
				<div class="p-10 md:p-20 bg-white hover:bg-[#FCFAFA] transition-colors group reveal-fade-up" style="transition-delay: 200ms;">
					<span class="text-2xl md:text-3xl font-['EB_Garamond'] text-[#a0ceca] mb-4 md:mb-6 block font-bold">02</span>
					<h3 class="text-2xl md:text-3xl font-bold mb-4 text-[#15303e] font-['EB_Garamond'] group-hover:translate-x-2 transition-transform">Local Expertise</h3>
					<p class="text-[#15303e]/60 leading-relaxed text-base md:text-lg font-light italic">A business solutions company based in Athens, GA, helping local business owners succeed.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
