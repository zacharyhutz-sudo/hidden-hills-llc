---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<section class="bg-blue-900 text-white py-32 flex items-center justify-center relative overflow-hidden">
		<div class="container mx-auto px-6 text-center z-10">
			<h1 class="text-5xl md:text-7xl font-extrabold mb-8 tracking-tight drop-shadow-lg leading-tight">Clarity for Your <br class="hidden md:block" /><span class="text-blue-400">Financial Future</span></h1>
			<p class="text-xl md:text-2xl text-blue-100 mb-12 max-w-2xl mx-auto leading-relaxed font-light">
				Expert bookkeeping, financial process optimization, and business consulting for modern enterprises.
			</p>
			<div class="flex flex-col sm:flex-row gap-6 justify-center">
				<a href="/services" class="bg-blue-600 hover:bg-blue-500 px-10 py-5 rounded-xl font-bold text-xl shadow-lg transition-all hover:scale-105">Our Services</a>
				<a href="/contact" class="bg-white hover:bg-gray-100 text-blue-900 px-10 py-5 rounded-xl font-bold text-xl shadow-lg transition-all hover:scale-105">Get Started</a>
			</div>
		</div>
		<div class="absolute inset-0 opacity-10 pointer-events-none">
			<svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
				<path d="M0 100 L100 0 L100 100 Z" fill="currentColor"></path>
			</svg>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="container mx-auto px-6">
			<div class="text-center max-w-3xl mx-auto mb-20">
				<h2 class="text-4xl font-bold text-gray-900 mb-6">Built for Efficiency</h2>
				<p class="text-xl text-gray-600 leading-relaxed font-light">
					We help you stop worrying about spreadsheets and start focusing on growth. 
					Hidden Hills LLC provides the financial backbone your business deserves.
				</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
				<div class="p-10 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
					<div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mb-8 text-blue-600 text-3xl font-bold">1</div>
					<h3 class="text-2xl font-bold mb-4">Precision Bookkeeping</h3>
					<p class="text-gray-600 leading-relaxed italic">Accuracy is our baseline. Financial clarity is our mission.</p>
				</div>
				<div class="p-10 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
					<div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mb-8 text-blue-600 text-3xl font-bold">2</div>
					<h3 class="text-2xl font-bold mb-4">Process Excellence</h3>
					<p class="text-gray-600 leading-relaxed italic">Optimizing every workflow. Cutting friction out of your business day.</p>
				</div>
				<div class="p-10 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
					<div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mb-8 text-blue-600 text-3xl font-bold">3</div>
					<h3 class="text-2xl font-bold mb-4">Expert Consulting</h3>
					<p class="text-gray-600 leading-relaxed italic">Strategic insights that go beyond the balance sheet.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
