---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
import curtis from '../assets/curtis-folsom.png';
---

<Layout title="Home">
	<section class="bg-[#ACC7C7] text-[#2C3E50] py-32 flex items-center justify-center relative overflow-hidden">
		<div class="container mx-auto px-6 z-10">
			<div class="flex flex-col md:flex-row items-center justify-center gap-12 md:gap-20">
				<div class="w-48 md:w-64 lg:w-80 shrink-0">
					<Image src={logo} alt="Hidden Hills LLC Logo" class="w-full h-auto drop-shadow-2xl" style="filter: brightness(0) saturate(100%) invert(18%) sepia(26%) saturate(1088%) hue-rotate(169deg) brightness(93%) contrast(89%);" />
				</div>
				<div class="text-center md:text-left max-w-2xl">
					<h1 class="text-5xl md:text-7xl font-bold mb-8 tracking-tight font-['Playfair_Display'] leading-tight">Focus on what <br class="hidden md:block" />you <span class="italic text-[#2C3E50]">really love</span></h1>
					<p class="text-xl md:text-2xl text-[#2C3E50]/80 mb-12 leading-relaxed font-medium">
						I'm Curtis Folsom, and I help business owners take the administrative load off their plate so they can grow their business.
					</p>
					<div class="flex flex-col sm:flex-row gap-6">
						<a href="/hidden-hills-llc/services" class="bg-[#2C3E50] hover:bg-[#1C2833] text-white px-10 py-5 rounded-xl font-bold text-xl shadow-lg transition-all hover:scale-105 text-center">View My Services</a>
						<a href="/hidden-hills-llc/contact" class="bg-white hover:bg-[#F4F6F7] text-[#2C3E50] px-10 py-5 rounded-xl font-bold text-xl shadow-lg transition-all hover:scale-105 border border-[#ACC7C7] text-center">Get in Touch</a>
					</div>
				</div>
			</div>
		</div>
		<div class="absolute inset-0 opacity-20 pointer-events-none">
			<svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
				<path d="M0 100 L100 0 L100 100 Z" fill="white"></path>
			</svg>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="container mx-auto px-6">
			<div class="flex flex-col md:flex-row gap-16 items-center">
				<div class="md:w-1/2">
					<div class="relative inline-block mb-8 md:mb-0">
						<Image src={curtis} alt="Curtis Folsom" class="rounded-3xl shadow-2xl w-full max-w-md h-auto relative z-10" />
						<div class="absolute -bottom-6 -right-6 w-full h-full border-4 border-[#ACC7C7] rounded-3xl z-0"></div>
					</div>
				</div>
				<div class="md:w-1/2">
					<h2 class="text-4xl font-bold text-[#2C3E50] mb-8 font-['Playfair_Display']">About Curtis</h2>
					<div class="space-y-6 text-lg text-[#5D6D7E] leading-relaxed font-medium">
						<p>
							I have an accounting degree from the University of Georgia and have financial experience in multiple industries. 
							What fuels me is solving problems and creating efficient systems to save time and energy.
						</p>
						<p>
							From multi-billion-dollar corporations to local businesses and nonprofits, I've worked with organizations of all sizes, 
							and I would love to bring my breadth of knowledge to your company.
						</p>
					</div>
					<div class="mt-10">
						<a href="/hidden-hills-llc/contact" class="text-[#2C3E50] font-bold text-lg border-b-2 border-[#ACC7C7] hover:border-[#2C3E50] transition-all pb-1">Let's chat about your needs &rarr;</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-24 bg-[#F4F6F7]">
		<div class="container mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				<div class="p-10 rounded-3xl bg-white border border-[#ACC7C7]/30 shadow-sm">
					<h3 class="text-2xl font-bold mb-4 text-[#2C3E50] font-['Playfair_Display']">Expert Systems</h3>
					<p class="text-[#5D6D7E] leading-relaxed italic">Leading software transitions, historical data cleanup, and bookkeeping excellence.</p>
				</div>
				<div class="p-10 rounded-3xl bg-white border border-[#ACC7C7]/30 shadow-sm">
					<h3 class="text-2xl font-bold mb-4 text-[#2C3E50] font-['Playfair_Display']">Local Expertise</h3>
					<p class="text-[#5D6D7E] leading-relaxed italic">A business solutions company based in Athens, GA, helping local business owners succeed.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
