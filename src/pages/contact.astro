---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
---

<Layout title="Contact">
	<section class="bg-[#ACC7C7] text-[#2C3E50] py-24 flex items-center justify-center relative overflow-hidden">
		<div class="container mx-auto px-6 z-10">
			<div class="flex flex-col md:flex-row items-center justify-center gap-10">
				<div class="w-32 md:w-40 shrink-0">
					<Image src={logo} alt="Hidden Hills LLC Logo" class="w-full h-auto drop-shadow-xl" />
				</div>
				<div class="text-center md:text-left">
					<h1 class="text-4xl md:text-6xl font-bold mb-4 tracking-tight font-['Playfair_Display']">Get in Touch</h1>
					<p class="text-lg md:text-xl text-[#2C3E50]/80 max-w-2xl mx-auto leading-relaxed font-medium italic">
						Let's chat about your business needs.
					</p>
				</div>
			</div>
		</div>
		<div class="absolute inset-0 opacity-20 pointer-events-none">
			<svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
				<path d="M0 100 L100 0 L100 100 Z" fill="white"></path>
			</svg>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-24 items-start">
			<div>
				<h2 class="text-3xl font-bold mb-6 text-[#2C3E50] leading-tight font-['Playfair_Display']">Contact Me</h2>
				<p class="text-[#5D6D7E] leading-relaxed text-lg mb-12 font-medium">
					Please reach out to me by emailing me, or calling/texting me to chat about your business needs!
				</p>
				<div class="space-y-12">
					<div class="flex items-start space-x-6">
						<div class="w-16 h-16 bg-[#AED6F1]/20 rounded-xl flex items-center justify-center text-[#2C3E50] shrink-0">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-[#2C3E50] mb-2 leading-snug font-['Playfair_Display']">Email Me</h3>
							<a href="mailto:curtis@hiddenhillsllc.com" class="text-[#5D6D7E] text-lg hover:text-[#2C3E50] transition-colors">curtis@hiddenhillsllc.com</a>
						</div>
					</div>
					<div class="flex items-start space-x-6">
						<div class="w-16 h-16 bg-[#AED6F1]/20 rounded-xl flex items-center justify-center text-[#2C3E50] shrink-0">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-[#2C3E50] mb-2 leading-snug font-['Playfair_Display']">Call or Text</h3>
							<a href="tel:7708414814" class="text-[#5D6D7E] text-lg hover:text-[#2C3E50] transition-colors">(770) 841-4814</a>
						</div>
					</div>
					<div class="flex items-start space-x-6">
						<div class="w-16 h-16 bg-[#AED6F1]/20 rounded-xl flex items-center justify-center text-[#2C3E50] shrink-0">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-[#2C3E50] mb-2 leading-snug font-['Playfair_Display']">Digital Business Card</h3>
							<a href="https://linktr.ee/hiddenhillsllc" target="_blank" class="text-[#5D6D7E] text-lg hover:text-[#2C3E50] transition-colors">linktr.ee/hiddenhillsllc</a>
						</div>
					</div>
				</div>
			</div>
			<div class="bg-[#F4F6F7] p-12 rounded-3xl border border-[#AED6F1]/30 shadow-lg">
				<form class="space-y-10">
					<div>
						<label class="block text-sm font-bold text-[#2C3E50] uppercase tracking-widest mb-4">Name</label>
						<input type="text" placeholder="Your Name" class="w-full px-6 py-4 rounded-xl border border-[#AED6F1]/30 focus:outline-none focus:ring-4 focus:ring-[#AED6F1]/20 transition-all bg-white" />
					</div>
					<div>
						<label class="block text-sm font-bold text-[#2C3E50] uppercase tracking-widest mb-4">Email</label>
						<input type="email" placeholder="Email Address" class="w-full px-6 py-4 rounded-xl border border-[#AED6F1]/30 focus:outline-none focus:ring-4 focus:ring-[#AED6F1]/20 transition-all bg-white" />
					</div>
					<div>
						<label class="block text-sm font-bold text-[#2C3E50] uppercase tracking-widest mb-4">Message</label>
						<textarea rows="5" placeholder="How can I help you save time and energy?" class="w-full px-6 py-4 rounded-xl border border-[#AED6F1]/30 focus:outline-none focus:ring-4 focus:ring-[#AED6F1]/20 transition-all bg-white"></textarea>
					</div>
					<button type="button" class="w-full bg-[#2C3E50] hover:bg-[#1C2833] text-white font-bold text-xl py-5 rounded-xl transition-all shadow-md hover:scale-105">Send Message</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
