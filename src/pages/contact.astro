---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
	<section class="bg-blue-900 text-white py-24 flex items-center justify-center">
		<div class="container mx-auto px-6 text-center">
			<h1 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tight drop-shadow-lg leading-tight">Ready to Work with Us?</h1>
			<p class="text-lg md:text-xl text-blue-100 max-w-2xl mx-auto leading-relaxed font-light italic">
				Let's build something efficient together. 
			</p>
		</div>
	</section>

	<section class="py-24 bg-white">
		<div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-24 items-start">
			<div>
				<h2 class="text-3xl font-bold mb-6 text-gray-900 leading-tight">Get in Touch</h2>
				<p class="text-gray-600 leading-relaxed text-lg mb-12 font-light italic">
					Whether you're looking for expert bookkeeping, financial process improvement, 
					or a custom spreadsheet built from scratch, we're here to help. 
					Reach out today for a consultation.
				</p>
				<div class="space-y-12">
					<div class="flex items-start space-x-6">
						<div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 shrink-0">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2 leading-snug">Email Us</h3>
							<p class="text-gray-600 text-lg hover:text-blue-700 transition-colors cursor-pointer">info@hiddenhillsllc.com</p>
						</div>
					</div>
					<div class="flex items-start space-x-6">
						<div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 shrink-0">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2 leading-snug">Call or Text</h3>
							<p class="text-gray-600 text-lg hover:text-blue-700 transition-colors cursor-pointer">(123) 456-7890</p>
						</div>
					</div>
					<div class="flex items-start space-x-6">
						<div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 shrink-0">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-gray-900 mb-2 leading-snug">Our Location</h3>
							<p class="text-gray-600 text-lg">Commerce, Georgia</p>
						</div>
					</div>
				</div>
			</div>
			<div class="bg-gray-50 p-12 rounded-3xl border border-gray-100 shadow-lg">
				<form class="space-y-10">
					<div>
						<label class="block text-sm font-bold text-gray-700 uppercase tracking-widest mb-4">Name</label>
						<input type="text" placeholder="Your Name" class="w-full px-6 py-4 rounded-xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-blue-100 transition-all" />
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-700 uppercase tracking-widest mb-4">Email</label>
						<input type="email" placeholder="Email Address" class="w-full px-6 py-4 rounded-xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-blue-100 transition-all" />
					</div>
					<div>
						<label class="block text-sm font-bold text-gray-700 uppercase tracking-widest mb-4">Message</label>
						<textarea rows="5" placeholder="How can we help your business thrive?" class="w-full px-6 py-4 rounded-xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-blue-100 transition-all"></textarea>
					</div>
					<button type="button" class="w-full bg-blue-700 hover:bg-blue-600 text-white font-bold text-xl py-5 rounded-xl transition-all shadow-md hover:scale-105">Send Message</button>
				</form>
			</div>
		</div>
	</section>
</Layout>
