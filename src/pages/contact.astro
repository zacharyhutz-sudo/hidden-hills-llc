---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';
---

<Layout title="Contact">
	<section class="bg-[#ACC7C7] text-[#2C3E50] py-24 flex items-center justify-center relative overflow-hidden">
		<div class="container mx-auto px-6 z-10">
			<div class="flex flex-col md:flex-row items-center justify-between gap-12">
				<div class="max-w-3xl">
					<span class="text-xs uppercase tracking-[0.3em] font-bold text-[#2C3E50]/40 mb-4 block">Connect</span>
					<h1 class="text-7xl md:text-9xl font-bold mb-6 tracking-tighter font-['EB_Garamond'] leading-none">Get in <br /><span class="italic font-normal">Touch.</span></h1>
				</div>
				<div class="w-24 md:w-32 lg:w-40 shrink-0">
					<Image src={logo} alt="Hidden Hills LLC Logo" class="w-full h-auto drop-shadow-xl opacity-20" style="filter: brightness(0) saturate(100%) invert(18%) sepia(26%) saturate(1088%) hue-rotate(169deg) brightness(93%) contrast(89%);" />
				</div>
			</div>
		</div>
	</section>

	<section class="py-24 bg-[#FCFAFA]">
		<div class="container mx-auto px-6">
			<div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
				<div class="lg:w-5/12">
					<h2 class="text-5xl font-bold text-[#2C3E50] mb-8 font-['EB_Garamond'] leading-tight text-balance">Let's chat about your business needs.</h2>
					<p class="text-xl text-[#2C3E50]/60 leading-relaxed font-light mb-12 max-w-md">
						Whether you're looking for a one-time project or ongoing administrative support, I'm here to help you reclaim your time.
					</p>
					
					<div class="space-y-10">
						<div>
							<span class="text-xs uppercase tracking-widest font-bold text-[#ACC7C7] mb-3 block">Based In</span>
							<p class="text-2xl font-['EB_Garamond'] text-[#2C3E50]">Athens, Georgia</p>
						</div>
						<div>
							<span class="text-xs uppercase tracking-widest font-bold text-[#ACC7C7] mb-3 block">Email</span>
							<a href="mailto:curtis@hiddenhillsllc.com" class="text-2xl font-['EB_Garamond'] text-[#2C3E50] border-b border-[#ACC7C7] hover:border-[#2C3E50] transition-colors">curtis@hiddenhillsllc.com</a>
						</div>
					</div>
				</div>
				
				<div class="lg:w-7/12">
					<form action="https://submit-form.com/YRiOEv7Ql" method="POST" class="space-y-10 bg-white p-10 md:p-16 rounded-[2.5rem] shadow-2xl shadow-[#2C3E50]/5 border border-[#2C3E50]/5">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
							<div class="space-y-2">
								<label for="name" class="text-xs uppercase tracking-widest font-bold text-[#2C3E50]/40">Your Name</label>
								<input type="text" id="name" name="name" class="w-full bg-transparent border-b border-[#2C3E50]/10 py-4 focus:border-[#ACC7C7] focus:outline-none transition-colors font-light text-lg" placeholder="Full Name" required />
							</div>
							<div class="space-y-2">
								<label for="business" class="text-xs uppercase tracking-widest font-bold text-[#2C3E50]/40">Business Name</label>
								<input type="text" id="business" name="business" class="w-full bg-transparent border-b border-[#2C3E50]/10 py-4 focus:border-[#ACC7C7] focus:outline-none transition-colors font-light text-lg" placeholder="Company" />
							</div>
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
							<div class="space-y-2">
								<label for="email" class="text-xs uppercase tracking-widest font-bold text-[#2C3E50]/40">Email Address</label>
								<input type="email" id="email" name="email" class="w-full bg-transparent border-b border-[#2C3E50]/10 py-4 focus:border-[#ACC7C7] focus:outline-none transition-colors font-light text-lg" placeholder="email@address.com" required />
							</div>
							<div class="space-y-2">
								<label for="phone" class="text-xs uppercase tracking-widest font-bold text-[#2C3E50]/40">Phone Number</label>
								<input type="tel" id="phone" name="phone" class="w-full bg-transparent border-b border-[#2C3E50]/10 py-4 focus:border-[#ACC7C7] focus:outline-none transition-colors font-light text-lg" placeholder="(555) 000-0000" />
							</div>
						</div>

						<div class="space-y-2">
							<label for="service" class="text-xs uppercase tracking-widest font-bold text-[#2C3E50]/40">What can I help with?</label>
							<select id="service" name="service" class="w-full bg-transparent border-b border-[#2C3E50]/10 py-4 focus:border-[#ACC7C7] focus:outline-none transition-colors font-light text-lg appearance-none cursor-pointer">
								<option value="" disabled selected>Select a Service</option>
								<option value="bookkeeping">Bookkeeping & Accounting</option>
								<option value="process">Process Improvement</option>
								<option value="automation">Spreadsheet Automation</option>
								<option value="special">Special Project</option>
								<option value="other">Other</option>
							</select>
						</div>

						<div class="space-y-2">
							<label for="message" class="text-xs uppercase tracking-widest font-bold text-[#2C3E50]/40">Additional Details</label>
							<textarea id="message" name="message" rows="4" class="w-full bg-transparent border-b border-[#2C3E50]/10 py-4 focus:border-[#ACC7C7] focus:outline-none transition-colors font-light text-lg resize-none" placeholder="Tell me more about your needs..." required></textarea>
						</div>
						
						<button type="submit" class="w-full py-5 bg-[#2C3E50] text-white rounded-full font-bold text-xs uppercase tracking-[0.2em] transition-all hover:scale-[1.02] active:scale-95 shadow-xl">
							Submit Request
						</button>
					</form>
				</div>
			</div>
		</div>
	</section>
</Layout>