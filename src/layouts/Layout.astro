---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';

interface Props {
	title: string;
}

const { title } = Astro.props;

const isHome = title === 'Home';
const isServices = title === 'Services';
const isContact = title === 'Contact';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Hidden Hills LLC</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FCFAFA] text-[#2C3E50] flex flex-col min-h-screen font-['Plus_Jakarta_Sans'] selection:bg-[#ACC7C7]/30 overflow-x-hidden">
		<div class="fixed inset-0 pointer-events-none opacity-[0.03] z-[100] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
		<header class="bg-[#FCFAFA]/80 backdrop-blur-md border-b border-[#2C3E50]/5 sticky top-0 z-50">
			<nav class="container mx-auto px-6 py-5 flex justify-between items-center">
				<a href="/hidden-hills-llc/" class="text-xl md:text-2xl font-bold text-[#2C3E50] tracking-tighter font-['EB_Garamond'] shrink-0">Hidden Hills <span class="text-[#2C3E50]/40 italic font-light">LLC</span></a>
				
				<!-- Desktop Nav -->
				<div class="hidden md:flex items-center space-x-12">
					<a href="/hidden-hills-llc/" class={`text-sm uppercase tracking-widest font-bold transition-colors ${isHome ? 'text-[#2C3E50]' : 'text-[#2C3E50]/60 hover:text-[#2C3E50]'}`}>Home</a>
					<a href="/hidden-hills-llc/services" class={`text-sm uppercase tracking-widest font-bold transition-colors ${isServices ? 'text-[#2C3E50]' : 'text-[#2C3E50]/60 hover:text-[#2C3E50]'}`}>Services</a>
					<a href="/hidden-hills-llc/contact" class="px-6 py-2 border border-[#2C3E50] text-xs uppercase tracking-widest font-bold hover:bg-[#2C3E50] hover:text-white transition-all">Contact</a>
				</div>

				<!-- Mobile Nav Links (Context Aware) -->
				<div class="flex md:hidden items-center space-x-4">
					{!isHome && <a href="/hidden-hills-llc/" class="text-[10px] uppercase tracking-widest font-bold text-[#2C3E50]/60">Home</a>}
					{!isServices && <a href="/hidden-hills-llc/services" class="text-[10px] uppercase tracking-widest font-bold text-[#2C3E50]/60">Services</a>}
					{!isContact && <a href="/hidden-hills-llc/contact" class="text-[10px] uppercase tracking-widest font-bold text-[#2C3E50]/60">Contact</a>}
				</div>
			</nav>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<script>
			const observerOptions = {
				root: null,
				rootMargin: '0px',
				threshold: 0.1
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('reveal-active');
						// Only unobserve if we don't want it to repeat
						// observer.unobserve(entry.target);
					}
				});
			}, observerOptions);

			// Initialize animations on load and when content changes
			const initAnimations = () => {
				const animatedElements = document.querySelectorAll('.reveal-text-content, .reveal-fade-up, .reveal-line');
				animatedElements.forEach(el => observer.observe(el));
			};

			document.addEventListener('DOMContentLoaded', initAnimations);
			document.addEventListener('astro:after-swap', initAnimations);
		</script>

		<footer class="bg-[#2C3E50] text-white py-16">
			<div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
				<div>
					<div class="flex items-center gap-3 mb-8">
						<Image src={logo} alt="Hidden Hills LLC Logo" class="h-10 w-auto brightness-0 invert opacity-40" />
						<h3 class="text-2xl font-bold font-['EB_Garamond']">Hidden Hills LLC</h3>
					</div>
					<p class="text-[#AED6F1]/40 leading-relaxed font-light">
						Helping business owners spend less time on paperwork and more time doing what they love. 
						Based in Athens, GA.
					</p>
				</div>
				<div>
					<h3 class="text-xs uppercase tracking-[0.3em] font-bold mb-10 text-[#AED6F1]">Quick Links</h3>
					<ul class="space-y-4 text-[#AED6F1]/40 text-sm font-medium">
						<li><a href="/hidden-hills-llc/" class="hover:text-white transition-colors">Home</a></li>
						<li><a href="/hidden-hills-llc/services" class="hover:text-white transition-colors">Services</a></li>
						<li><a href="/hidden-hills-llc/contact" class="hover:text-white transition-colors">Contact</a></li>
					</ul>
				</div>
				<div>
					<h3 class="text-xs uppercase tracking-[0.3em] font-bold mb-10 text-[#AED6F1]">Connect</h3>
					<p class="text-[#AED6F1]/40 mb-8 font-light italic">Let me help you take the administrative load off your plate.</p>
					<a href="/hidden-hills-llc/contact" class="inline-flex items-center justify-center px-10 py-4 bg-[#ACC7C7] text-[#2C3E50] font-bold text-xs uppercase tracking-widest transition-all hover:scale-105 active:scale-95">
						Get in Touch
					</a>
				</div>
			</div>
			<div class="container mx-auto px-6 mt-16 pt-8 border-t border-[#5D6D7E]/30 text-center text-[#5D6D7E] text-sm font-medium">
				&copy; {new Date().getFullYear()} Hidden Hills LLC. All rights reserved.
			</div>
		</footer>
	</body>
</html>
