---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../assets/logo-transparent.png';

interface Props {
	title: string;
}

const { title } = Astro.props;

const isHome = title === 'Home';
const isServices = title === 'Services';
const isContact = title === 'Contact';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Hidden Hills Bookkeeping</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#FCFAFA] text-[#15303e] flex flex-col min-h-screen font-['Plus_Jakarta_Sans'] selection:bg-[#a0ceca]/30 overflow-x-hidden">
		<div class="fixed inset-0 pointer-events-none opacity-[0.03] z-[100] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
		<header class="bg-[#FCFAFA]/80 backdrop-blur-md border-b border-[#15303e]/5 sticky top-0 z-50">
			<nav class="container mx-auto px-6 py-5 flex justify-between items-center">
				<a href="/" class="text-xl md:text-2xl font-bold text-[#15303e] tracking-tighter font-['EB_Garamond'] shrink-0">Hidden Hills <span class="text-[#15303e]/40 italic font-light">Bookkeeping</span></a>
				
				<!-- Desktop Nav -->
				<div class="hidden md:flex items-center space-x-12">
					<a href="/" class={`text-sm uppercase tracking-widest font-bold transition-colors ${isHome ? 'text-[#15303e]' : 'text-[#15303e]/60 hover:text-[#15303e]'}`}>Home</a>
					<a href="/services" class={`text-sm uppercase tracking-widest font-bold transition-colors ${isServices ? 'text-[#15303e]' : 'text-[#15303e]/60 hover:text-[#15303e]'}`}>Services</a>
					<a href="/contact" class="px-6 py-2 border border-[#15303e] text-xs uppercase tracking-widest font-bold hover:bg-[#15303e] hover:text-white transition-all">Contact</a>
				</div>

				<!-- Mobile Nav Links (Context Aware) -->
				<div class="flex md:hidden items-center space-x-4">
					{!isHome && <a href="/" class="text-[10px] uppercase tracking-widest font-bold text-[#15303e]/60">Home</a>}
					{!isServices && <a href="/services" class="text-[10px] uppercase tracking-widest font-bold text-[#15303e]/60">Services</a>}
					{!isContact && <a href="/contact" class="text-[10px] uppercase tracking-widest font-bold text-[#15303e]/60">Contact</a>}
				</div>
			</nav>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<script>
			const initAnimations = () => {
				const observerOptions = {
					root: null,
					rootMargin: '0px',
					threshold: 0.01 // Very low threshold to ensure it triggers
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('reveal-active');
						}
					});
				}, observerOptions);

				const animatedElements = document.querySelectorAll('.reveal-text-content, .reveal-fade-up, .reveal-line, .reveal-hero');
				animatedElements.forEach(el => observer.observe(el));

				// Force reveal for elements already in view (like the Hero)
				setTimeout(() => {
					animatedElements.forEach(el => {
						const rect = el.getBoundingClientRect();
						if (rect.top < window.innerHeight && rect.bottom > 0) {
							el.classList.add('reveal-active');
						}
					});
				}, 100);
			};

			// Run on initial load
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initAnimations);
			} else {
				initAnimations();
			}

			// Run after view transitions
			document.addEventListener('astro:after-swap', initAnimations);
		</script>

		<footer class="bg-[#15303e] text-white py-16">
			<div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
				<div>
					<div class="flex items-center gap-3 mb-8">
						<Image src={logo} alt="Hidden Hills Bookkeeping Logo" class="h-10 w-auto brightness-0 invert opacity-40" />
						<h3 class="text-2xl font-bold font-['EB_Garamond']">Hidden Hills Bookkeeping</h3>
					</div>
					<p class="text-[#a0ceca]/40 leading-relaxed font-light">
						Helping business owners spend less time on paperwork and more time doing what they love. 
						Based in Athens, GA.
					</p>
				</div>
				<div>
					<h3 class="text-xs uppercase tracking-[0.3em] font-bold mb-10 text-[#a0ceca]">Quick Links</h3>
					<ul class="space-y-4 text-[#a0ceca]/40 text-sm font-medium">
						<li><a href="/" class="hover:text-white transition-colors">Home</a></li>
						<li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
						<li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
					</ul>
				</div>
				<div>
					<h3 class="text-xs uppercase tracking-[0.3em] font-bold mb-10 text-[#a0ceca]">Connect</h3>
					<p class="text-[#a0ceca]/40 mb-8 font-light italic">Let me help you take the administrative load off your plate.</p>
					<a href="/contact" class="inline-flex items-center justify-center px-10 py-4 bg-[#a0ceca] text-[#15303e] font-bold text-xs uppercase tracking-widest transition-all hover:scale-105 active:scale-95">
						Get in Touch
					</a>
				</div>
			</div>
			<div class="container mx-auto px-6 mt-16 pt-8 border-t border-white/10 text-center text-white/30 text-sm font-medium">
				<p>&copy; {new Date().getFullYear()} Hidden Hills Bookkeeping. All rights reserved.</p>
				<p class="mt-4 text-[10px] uppercase tracking-[0.2em] opacity-50 hover:opacity-100 transition-opacity">
					Design by <span class="font-bold text-white/50">Hutzell Creative Co</span>
				</p>
			</div>
		</footer>
	</body>
</html>
